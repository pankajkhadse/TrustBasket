{
  "compilerOptions": {
    "lib": [
      "dom",
      "dom.iterable",
      "esnext"
    ],
    "types": ["node"],
    "allowJs": true,
    "target": "ES6",
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@/*": [
        "./*"
      ]
    }
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts",
    "app/vendor/orders/page.tsx",
    "app/admin/verifications/loading.js",
    "app/admin/verifications/page.tsx",
    "app/delivery/tracking/page.js",
    "app/map/locations/page.js",
    "app/supplier/dashboard/page.tsx",
    "app/supplier/inventory/page.tsx",
    "app/supplier/orders/page.tsx",
    "app/vendor/marketplace/page.tsx"
  ],
  "exclude": [
    "node_modules"
  ]
}